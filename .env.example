# ============================================================
#  환경 변수 예시 파일 (협업용 — 실제 값 없음)
#  사용 방법: 이 파일을 복사해서 .env 로 이름 변경 후 값 채우기
#    cp .env.example .env
# ============================================================

# ─── 실계좌 (알림 봇 전용) ───
APP_KEY=YOUR_APP_KEY_HERE
APP_SECRET=YOUR_APP_SECRET_HERE
ACC_NO=YOUR_ACCOUNT_NUMBER
IS_MOCK=False

# ─── 모의투자 (스캘핑 자동매매 전용) ───
# KIS Developers에서 모의투자용 앱을 별도 등록해야 합니다.
KIS_MOCK_APPKEY=YOUR_MOCK_APP_KEY_HERE
KIS_MOCK_APPSECRET=YOUR_MOCK_APP_SECRET_HERE
KIS_MOCK_ACC_NO=YOUR_MOCK_ACCOUNT_NUMBER

# ─── 텔레그램 봇 ───
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=TELEGRAM_CHAT_ID

# ─── Anthropic Claude API (일일 AI 브리핑용) ───
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY